# Twilio Programmable Voice
# Account SID (AC + 32 hex) — Console home, top-right.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API Key SID (SK + 32 hex) and Secret — Console → Account → API keys & tokens.
# The Secret is shown once at creation; create a new key if you've lost it.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
TWILIO_PHONE_NUMBER=+15551234567

# LLM / STT / TTS providers. Gemini handles both STT and the dialog LLM.
GEMINI_API_KEY=your-google-genai-key
GRADIUM_API_KEY=your-gradium-key

# Optional Gemini model overrides. Google rotates Live model IDs often;
# set these if the defaults stop working without redeploying code.
# GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
# GEMINI_LLM_MODEL=gemini-2.5-flash

# Default Gradium voice (copied from Gradium Studio). Required unless
# LANGUAGE_VOICE_MAP covers every entry in SUPPORTED_LANGUAGES.
GRADIUM_VOICE_ID=voice_default_xxx
# Optional staging override for Gradium endpoint. Leave unset for production.
# GRADIUM_ENDPOINT=

# Optional: per-language voice override. Format: lang=voiceId,lang=voiceId
# Wins over GRADIUM_VOICE_ID for the listed languages.
# LANGUAGE_VOICE_MAP=en=voice_en_xxx,de=voice_de_xxx

# Storage
DATABASE_URL=postgresql+asyncpg://intake:intake@localhost:5432/intake
REDIS_URL=redis://localhost:6379/0

# Public URL Twilio reaches (ngrok in dev, ALB hostname in prod)
PUBLIC_BASE_URL=https://your-ngrok-or-prod-host

# Locale
DEFAULT_LANGUAGE=en
# Must be a subset of Gradium's supported set: en,de,es,fr,pt
SUPPORTED_LANGUAGES=en,de,es,fr,pt

# Misc
LOG_LEVEL=INFO
SLA_HOURS=24
COMPANY_NAME=Acme Insurance
