# Ngrok Configuration (for local development with Twilio)
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_API_KEY_SID=your_twilio_api_key_sid_here
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here
TWILIO_PHONE_NUMBER=+1234567890

# AI Service API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GRADIUM_API_KEY=your_gradium_api_key_here


# Gradium TTS Configuration
GRADIUM_TTS_VOICE_ID=default_voice_id
GRADIUM_TTS_ENDPOINT=wss://api.gradium.ai/api/speech/tts

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/claims_db

# Application Configuration
# For local development with ngrok, this will be your ngrok URL (e.g., https://abc123.ngrok-free.app)
# Get this from http://localhost:4040 after starting ngrok
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de,es,fr,pt
LOG_LEVEL=INFO

# STT Provider Configuration
# IMPORTANT: Gemini Live API is not yet available in google-generativeai package
# Use 'google_cloud' for production deployments
# Options:
#   - 'gemini': Uses Gemini Live API (NOT CURRENTLY AVAILABLE - will show error)
#   - 'google_cloud': Uses Google Cloud Speech-to-Text (RECOMMENDED - requires GCP credentials)
STT_PROVIDER=google_cloud

# Google Cloud Speech-to-Text Configuration (required if STT_PROVIDER=google_cloud)
# Set this to the path of your Google Cloud service account JSON key file
# See documentation/GOOGLE_CLOUD_STT_SETUP.md for setup instructions
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Security
SECRET_KEY=your_secret_key_here_change_in_production

# Data Retention (days)
AUDIO_RETENTION_DAYS=30
TRANSCRIPT_RETENTION_DAYS=90