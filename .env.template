# =============================================================================
# AI Claims Intake System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# TWILIO CONFIGURATION (Required for phone calls)
# -----------------------------------------------------------------------------
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# AI SERVICE API KEYS (Required)
# -----------------------------------------------------------------------------
# Gemini API Key - Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gradium API Key - Contact Gradium for access
GRADIUM_API_KEY=your_gradium_api_key_here

# -----------------------------------------------------------------------------
# GOOGLE CLOUD SPEECH-TO-TEXT (Recommended for Production)
# -----------------------------------------------------------------------------
# See documentation/GOOGLE_CLOUD_STT_SETUP.md for setup instructions
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-stt-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# -----------------------------------------------------------------------------
# GRADIUM TTS CONFIGURATION
# -----------------------------------------------------------------------------
GRADIUM_TTS_VOICE_ID=default_voice_id
GRADIUM_TTS_ENDPOINT=wss://api.gradium.ai/api/speech/tts

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# For local development (using Docker Compose):
DATABASE_URL=postgresql+asyncpg://claims_user:claims_password@localhost:5432/claims_db

# For production, use your actual database credentials:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# For local development with ngrok:
# 1. Start ngrok: ngrok http 8000
# 2. Copy the URL from http://localhost:4040
# 3. Update PUBLIC_BASE_URL below
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Language settings
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de,es,fr,pt

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# STT PROVIDER CONFIGURATION
# -----------------------------------------------------------------------------
# Options: 'google_cloud' (recommended) or 'gemini' (requires Live API access)
STT_PROVIDER=google_cloud

# -----------------------------------------------------------------------------
# SECURITY (Required)
# -----------------------------------------------------------------------------
# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_change_in_production

# -----------------------------------------------------------------------------
# DATA RETENTION (Optional)
# -----------------------------------------------------------------------------
AUDIO_RETENTION_DAYS=30
TRANSCRIPT_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# NGROK CONFIGURATION (Optional - for local development)
# -----------------------------------------------------------------------------
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
# [ ] Copy this file to .env
# [ ] Fill in all TWILIO_* values
# [ ] Fill in GEMINI_API_KEY
# [ ] Fill in GRADIUM_API_KEY
# [ ] Set up Google Cloud STT (see documentation/GOOGLE_CLOUD_STT_SETUP.md)
# [ ] Generate and set SECRET_KEY
# [ ] Update PUBLIC_BASE_URL after starting ngrok
# [ ] Start PostgreSQL: docker compose -f infra/docker-compose.yml up -d postgres
# [ ] Run migrations: alembic upgrade head
# [ ] Test the setup: python scripts/test_google_cloud_stt.py
# =============================================================================